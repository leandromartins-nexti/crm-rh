{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-bash.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date -Iseconds)] subagent finished: $CLAUDE_AGENT_TYPE\" >> $CLAUDE_PROJECT_DIR/.claude/pipeline.log"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --abbrev-ref HEAD 2>/dev/null | xargs -I{} echo \"Sessão iniciada em branch: {}\""
          }
        ]
      }
    ]
  }
}
